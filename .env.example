# ---- Auth ----
JWT_SECRET=change-me-in-production-please-32chars-minimum
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ---- Frontend -> Backend base URL (as seen from the browser) ----
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ---- Optional: enable Claude-powered agent augmentation ----
# Without a key the platform runs fully offline on deterministic heuristics.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
